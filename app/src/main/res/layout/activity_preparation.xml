<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".viewModel.PreparationActivity"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".viewModel.PreparationActivity">

        <TextView
            android:id="@+id/title_preparation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/montserrat_medium"
            android:text="@string/title_preparazione"
            android:textColor="@color/black"
            android:textSize="24sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/horizzontalBarrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="title_preparation"
            app:layout_constraintBottom_toTopOf="@id/cardViewTitleExam"
            app:layout_constraintTop_toBottomOf="@id/title_preparation" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardViewTitleExam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title_preparation">

            <ImageView
                android:id="@+id/imageview_card"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_margin="10dp"
                android:src="@drawable/baseline_menu_book_24" />

            <TextView
                android:id="@+id/titleCardView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="80dp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/montserrat_light"
                android:text="TITOLO ESAME"
                android:textColor="@color/black"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/Cfu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="80dp"
                android:layout_marginTop="35dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/montserrat_light"
                android:text="@string/Cfu"
                android:textColor="@color/black"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/numCfu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="150dp"
                android:layout_marginTop="35dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/montserrat_light"
                android:text=""
                android:textColor="@color/black"
                android:textSize="15sp"
                android:layout_gravity="right"/>

            <TextView
                android:id="@+id/docente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="80dp"
                android:layout_marginTop="58dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/montserrat_light"
                android:text="@string/nameDocente"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/nomeDocente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="150dp"
                android:layout_marginTop="58dp"
                android:layout_marginEnd="20dp"
                android:layout_gravity="right"
                android:fontFamily="@font/montserrat_light"
                android:text=""
                android:textColor="@color/black"
                android:textSize="15sp" />

        </androidx.cardview.widget.CardView>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/menuChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.502"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardViewTitleExam"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipInfoGenerali"
                style="@style/CustomChipStyle"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_light"
                android:textAlignment="center"
                android:text="@string/title_chip_Info" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMateriale"
                style="@style/CustomChipStyle"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_light"
                android:textAlignment="center"
                android:text="@string/title_chip_Materiale" />
        </com.google.android.material.chip.ChipGroup>

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragmentContainerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/menuChip"
            android:paddingBottom="10dp">
        </androidx.fragment.app.FragmentContainerView>


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>

