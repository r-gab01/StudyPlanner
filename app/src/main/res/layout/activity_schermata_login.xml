<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SchermataLogin">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="148dp"
        android:layout_height="139dp"
        android:layout_marginVertical="50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@drawable/logo" />

    <EditText
        android:id="@+id/EditTextNomeUtente"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="60dp"
        android:layout_marginRight="20dp"
        android:background="@drawable/edit_text_border"
        android:drawableLeft="@drawable/baseline_person_24"
        android:focusable="false"
        android:paddingLeft="10dp"
        android:focusableInTouchMode="false"
        android:gravity="center_vertical"
        android:hint=" |  Inserisci Nome Utente"
        android:outlineProvider="none"
        android:textSize="23dp"
        android:textStyle="bold"
        android:fontFamily="@font/montserrat_medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView" />

    <EditText
        android:id="@+id/EditTextPassword"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="60dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:paddingLeft="10dp"
        android:background="@drawable/edit_text_border"
        android:drawableLeft="@drawable/baseline_lock_24"
        android:fontFamily="@font/montserrat_medium"
        android:gravity="center_vertical"
        android:hint=" |  Inserisci Password"
        android:textSize="23dp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/EditTextNomeUtente"
        app:layout_constraintTop_toBottomOf="@id/EditTextNomeUtente" />

    <CheckBox
        android:id="@+id/checkBox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:background="@drawable/edit_text_border"
        android:fontFamily="@font/montserrat_medium"
        android:paddingRight="15dp"
        android:text="Ricordami"
        android:paddingLeft="5dp"
        android:textColor="@color/black"
        android:textSize="18dp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/EditTextNomeUtente"
        app:layout_constraintTop_toBottomOf="@+id/EditTextPassword" />

    <TextView
        android:id="@+id/textViewPasswordDimenticata"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginVertical="15dp"
        android:layout_marginTop="20dp"
        android:clickable="true"
        android:fontFamily="@font/montserrat_medium"
        android:text=" Hai dimenticato la password?"
        android:paddingRight="5dp"
        android:textColor="#0037FF"
        android:textSize="17dp"
        app:layout_constraintStart_toStartOf="@+id/checkBox"
        app:layout_constraintTop_toBottomOf="@+id/checkBox" />

    <Button
        android:id="@+id/button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Login"
        android:textStyle="bold"
        android:backgroundTint="#4CAF50"
        android:layout_marginTop="30dp"
        android:textSize="18dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewPasswordDimenticata" />
</androidx.constraintlayout.widget.ConstraintLayout>