<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context=".SchermataRecuperoPass">

    <TextView
        android:id="@+id/textTitleRecupero"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_recupera_pass"
        android:textSize="30dp"
        android:layout_marginLeft="15dp"
        android:fontFamily="@font/montserrat_medium"
        android:textColor="@color/black"
        android:layout_marginTop="35dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/textTitleRecupero"
        android:layout_marginTop="10dp"
        android:layout_marginRight="5dp"
        android:layout_marginLeft="5dp"
        android:background="@drawable/edit_text_border"
        android:paddingLeft="15dp"
        android:paddingRight="15dp"
        android:paddingBottom="10dp">


        <TextView
            android:id="@+id/textViewInfoRecupero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="15dp"
            android:layout_marginRight="20dp"
            android:fontFamily="@font/montserrat_medium"
            android:text="@string/subtitle_recupera_pass"
            android:textColor="#2E2E2E"
            android:textSize="19dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            />

        <TextView
            android:id="@+id/mostraAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textViewInfoRecupero" />

        <TextView
            android:id="@+id/titleDomandaSicurezza"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/montserrat_medium"
            android:text="@string/title_domanda"
            android:textColor="@color/black"
            android:textSize="19dp"
            app:layout_constraintStart_toStartOf="@+id/textViewInfoRecupero"
            app:layout_constraintTop_toBottomOf="@+id/mostraAccount" />

        <TextView
            android:id="@+id/domandaSic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:text=""
            app:layout_constraintStart_toStartOf="@+id/titleDomandaSicurezza"
            app:layout_constraintTop_toBottomOf="@+id/titleDomandaSicurezza" />


        <EditText
            android:id="@+id/campoInserisciRisposta"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="45dp"
            android:layout_marginRight="20dp"
            android:background="@drawable/edit_text_border"
            android:hint="@string/risposta"
            android:textSize="18dp"
            android:paddingLeft="15dp"
            app:layout_constraintTop_toBottomOf="@+id/titleDomandaSicurezza" />

        <TextView
            android:id="@+id/mostraPass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintStart_toStartOf="@+id/campoInserisciRisposta"
            app:layout_constraintTop_toBottomOf="@+id/campoInserisciRisposta" />

        <Button
            android:id="@+id/button2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_conferma"
            android:layout_gravity="center"
            android:textSize="18dp"
            android:layout_marginTop="30dp"
            android:backgroundTint="#4CAF50"
            />


    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>